  "guidelines": {
    "wcag_compliance": {
      "text_contrast_minimum": 4.5,
      "graphics_contrast_minimum": 3.0,
      "large_text_threshold": "18pt or 14pt bold"
    },
    "accessibility": {
      "semantic_html": "Use proper semantic tags: <main>, <section>, <article>, <nav>",
      "aria_labels": "Always provide aria-labels for regions and custom controls",
      "keyboard_navigation": "Ensure all interactive elements are keyboard accessible",
      "color_not_only_indicator": "Do not rely on color alone to convey meaning"
    },
    "ai_guidance": {
      "when_generating_ui": "AI systems should use --surface-primary, --text-body, --interactive-primary, and --feedback-* tokens instead of hardcoding colors",
      "semantic_token_usage": "Always use semantic tokens (e.g., --text-body not --text-muted) unless a specific visual hierarchy requires otherwise",
      "theme_switching": "Generated HTML/CSS must work in both light and dark modes by using CSS variables",
      "contrast_checking": "For critical content, verify contrast ratios match WCAG AA standards before generating"
    }
  }
